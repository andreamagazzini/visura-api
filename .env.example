# Variabili d'ambiente per il servizio Visura API
# Copia questo file in .env e inserisci le tue credenziali:
#   cp .env.example .env

# === Credenziali SPID / Agenzia delle Entrate ===
ADE_USERNAME=il_tuo_codice_fiscale
ADE_PASSWORD=la_tua_password

# Metodo login all'avvio del servizio:
#   spid (default) — flusso SPID / notifica push come in utils.login()
#   sister_tab — login IAM tab "SISTER" solo utente/password (vedi login_sister_tab in utils.py)
# LOGIN_METHOD=spid

# URL pagina login IAM (usato con LOGIN_METHOD=sister_tab)
# SISTER_LOGIN_URL=https://iampe.agenziaentrate.gov.it/sam/UI/Login?realm=/agenziaentrate

# Tempo massimo (ms) per attendere redirect / conferma sessione dopo il login Sister (default 60000)
# SISTER_LOGIN_CONFIRM_TIMEOUT_MS=60000

# Timeout Playwright per fill username/password su IAM (default 25000 ms)
# SISTER_LOGIN_FILL_TIMEOUT_MS=25000

# === Configurazione opzionale ===

# Livello di log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Numero di worker concorrenti
CONCURRENT_WORKERS=3

# Directory dove salvare gli HTML delle pagine visitate dal browser per debug.
# Se non scrivibile, il servizio prova /tmp/visura-api/logs/pages come fallback;
# se anche quella non è scrivibile, il logging delle pagine viene disabilitato
# silenziosamente (il resto del servizio continua a funzionare).
# PAGES_LOG_DIR=./logs/pages

# Opzionale: protezione degli endpoint POST /session/login e /session/logout
# (stesso valore va inviato dall'app Next come header X-Visura-Session-Secret)
# VISURA_SESSION_SECRET=una-stringa-segreta

# Non modificare queste (necessarie per Playwright in Docker)
PYTHONUNBUFFERED=1
DISPLAY=:99
